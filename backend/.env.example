# Server port (Render sets this automatically in production)
PORT=3001

# Postgres connection string (Neon, Render Postgres, etc.)
# On Neon, use the POOLED connection string (hostname contains "-pooler") —
# this is what the app uses at runtime.
DATABASE_URL=

# Required on Neon: the DIRECT (non-pooled) connection string — same as
# DATABASE_URL but with "-pooler" removed from the hostname. Migrations need
# this because Postgres advisory locks (which `prisma migrate deploy` uses)
# don't work reliably through Neon's pooler and will time out (P1002) if
# DATABASE_URL is used for migrations. Get the exact value from Neon's
# dashboard: Connect > uncheck "Pooled connection".
DIRECT_DATABASE_URL=

# Any long random string, used to sign admin + customer JWTs
JWT_SECRET=

# URL of the deployed frontend (Vercel), used for CORS + cookie origin.
# In local dev, leave unset and it defaults to http://localhost:3000
CLIENT_URL=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Set to "production" on Render — enables secure cookies + cross-site cookie mode
NODE_ENV=development
